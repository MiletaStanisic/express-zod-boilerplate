{
  "name": "express-zod-boilerplate",
  "version": "0.1.0",
  "private": false,
  "description": "Production-oriented Express + TypeScript backend boilerplate",
  "type": "module",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "db:migrate": "tsx src/db/run-migrations.ts",
    "db:migrate:revert": "tsx src/db/revert-migration.ts",
    "db:migrate:status": "tsx src/db/show-migrations.ts",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app",
    "docker:ps": "docker compose ps",
    "docker:validate": "docker compose config > /dev/null",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "skills:sync": "node scripts/skills-sync.mjs",
    "skills:verify": "node scripts/skills-verify.mjs"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.26",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.35.0",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.41.0",
    "vitest": "^3.2.4"
  }
}
